<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI-Driven Contract & Approval Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #FAF7F2;
  --parchment: #F2EDE3;
  --warm-white: #FFFDF9;
  --ink: #1C1410;
  --ink-soft: #3D2F25;
  --ink-muted: #7A6558;
  --ink-faint: #B5A99E;
  --border: #DDD4C7;
  --border-soft: #EDE6DC;
  --rust: #C4512A;
  --rust-light: #F5E8E1;
  --gold: #A67C3A;
  --gold-light: #F5EDDB;
  --gold-mid: #D4A854;
  --forest: #2D5C3E;
  --forest-light: #E3EDE7;
  --navy: #1E3358;
  --navy-light: #E2E8F2;
  --navy-mid: #3D6094;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--cream);
  color: var(--ink);
  font-family: 'Crimson Pro', Georgia, serif;
  font-size: 17px;
  font-weight: 300;
  line-height: 1.75;
  overflow-x: hidden;
}
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 48px;
  background: rgba(250,247,242,0.94);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--ink);
  text-transform: uppercase;
}
.nav-logo span { color: var(--rust); }
.nav-links { display: flex; gap: 4px; }
.nav-link {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 6px 14px;
  border: 1px solid transparent;
  color: var(--ink-muted);
  cursor: pointer;
  background: none;
  transition: all 0.2s;
  border-radius: 1px;
}
.nav-link:hover { border-color: var(--border); background: var(--parchment); color: var(--ink); }

/* HERO */
.hero {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120px 48px 80px;
  background: var(--warm-white);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.hero-wm {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-family: 'Playfair Display', serif;
  font-size: 340px;
  font-weight: 900;
  font-style: italic;
  color: transparent;
  -webkit-text-stroke: 1px rgba(196,81,42,0.055);
  pointer-events: none;
  white-space: nowrap;
  user-select: none;
  letter-spacing: -0.05em;
}
.hero-rule { width: 72px; height: 2px; background: var(--rust); margin: 0 auto 26px; animation: fadeUp 0.7s ease both; }
.hero-eyebrow {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 10px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--rust); margin-bottom: 20px; animation: fadeUp 0.7s 0.08s ease both;
}
.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 6.5vw, 84px);
  font-weight: 400; line-height: 1.07; letter-spacing: -0.02em;
  color: var(--ink); margin-bottom: 26px; animation: fadeUp 0.7s 0.14s ease both;
}
.hero h1 em { font-style: italic; color: var(--rust); }
.hero-sub {
  font-family: 'Crimson Pro', serif;
  font-size: clamp(17px, 2vw, 22px); font-weight: 300; font-style: italic;
  color: var(--ink-muted); max-width: 540px; margin: 0 auto 48px; line-height: 1.6;
  animation: fadeUp 0.7s 0.2s ease both;
}
.outcome-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; animation: fadeUp 0.7s 0.26s ease both; }
.outcome-pill {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 8px 18px; border: 1px solid var(--border); color: var(--ink-soft); background: var(--parchment);
}
.scroll-cue {
  position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 10px; color: var(--ink-faint);
}
.scroll-cue span { font-family: 'Space Grotesk', sans-serif; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; }
.scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--rust), transparent); animation: sc 2s ease-in-out infinite; }
@keyframes sc { 0%,100%{opacity:0.3} 50%{opacity:1} }
@keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }

/* MAIN */
main { position: relative; z-index: 1; max-width: 1160px; margin: 0 auto; padding: 0 48px 120px; }

/* CHAPTER */
.chapter { padding: 80px 0 0; opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.chapter.visible { opacity: 1; transform: translateY(0); }
.chapter-top {
  display: grid; grid-template-columns: 80px 1fr;
  gap: 24px; align-items: start; margin-bottom: 36px;
  padding-bottom: 32px; border-bottom: 1px solid var(--border);
}
.chapter-num { font-family: 'Playfair Display', serif; font-size: 66px; font-weight: 900; font-style: italic; line-height: 1; padding-top: 4px; }
.num-rust{color:var(--rust)} .num-gold{color:var(--gold)} .num-forest{color:var(--forest)} .num-navy{color:var(--navy)}
.chapter-kicker { font-family: 'Space Grotesk', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 8px; }
.kk-rust{color:var(--rust)} .kk-gold{color:var(--gold)} .kk-forest{color:var(--forest)} .kk-navy{color:var(--navy)}
.chapter-title { font-family: 'Playfair Display', serif; font-size: clamp(24px,3.5vw,38px); font-weight: 700; line-height: 1.12; letter-spacing: -0.015em; color: var(--ink); margin-bottom: 8px; }
.chapter-ref { font-family: 'Space Grotesk', sans-serif; font-size: 11px; color: var(--ink-faint); letter-spacing: 0.04em; }

/* GRID */
.cg { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: var(--border); border: 1px solid var(--border); margin-bottom: 2px; }
.cg.full { grid-template-columns: 1fr; }
.cell { background: var(--warm-white); padding: 28px 30px; transition: background 0.2s; }
.cell:hover { background: var(--parchment); }
.cell-head {
  font-family: 'Space Grotesk', sans-serif; font-size: 10px; font-weight: 600;
  letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-muted);
  margin-bottom: 18px; display: flex; align-items: center; gap: 10px;
}
.cr { display: inline-block; width: 24px; height: 2px; flex-shrink: 0; border-radius: 1px; }
.cr-rust{background:var(--rust)} .cr-gold{background:var(--gold)} .cr-forest{background:var(--forest)} .cr-navy{background:var(--navy)}

/* FEATURE LIST */
.fl { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.fl li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; font-weight: 300; color: var(--ink-soft); line-height: 1.55; }
.fl li .mk { font-family: 'Playfair Display', serif; font-style: italic; font-size: 14px; flex-shrink: 0; margin-top: 2px; opacity: 0.45; }
.fl li strong { font-weight: 600; color: var(--ink); }
.sub { list-style: none; padding-left: 18px; margin-top: 4px; display: flex; flex-direction: column; gap: 3px; }
.sub li { font-size: 13px; color: var(--ink-faint); line-height: 1.5; }
.sub li::before { content: '— '; color: var(--ink-faint); font-style: italic; }

/* CALLOUT */
.co { margin-top: 18px; padding: 15px 20px; border-left: 3px solid; background: var(--parchment); border-radius: 0 1px 1px 0; }
.co-rust{border-color:var(--rust)} .co-gold{border-color:var(--gold)} .co-forest{border-color:var(--forest)} .co-navy{border-color:var(--navy)}
.co-label { font-family: 'Space Grotesk', sans-serif; font-size: 9px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 6px; }
.co-rust .co-label{color:var(--rust)} .co-gold .co-label{color:var(--gold)} .co-forest .co-label{color:var(--forest)} .co-navy .co-label{color:var(--navy)}
.co p { font-family: 'Crimson Pro', serif; font-size: 15px; font-style: italic; color: var(--ink-soft); line-height: 1.6; }
.co p strong { font-style: normal; font-weight: 600; color: var(--ink); }

/* STAT STRIP */
.stat-strip { display: flex; gap: 2px; background: var(--border); border: 1px solid var(--border); margin-bottom: 2px; }
.stat-block { flex: 1; background: var(--warm-white); padding: 24px 20px; text-align: center; transition: background 0.2s; }
.stat-block:hover { background: var(--gold-light); }
.stat-num { font-family: 'Playfair Display', serif; font-size: 38px; font-weight: 700; line-height: 1; margin-bottom: 6px; color: var(--gold); }
.stat-lbl { font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 500; color: var(--ink-muted); letter-spacing: 0.05em; line-height: 1.4; }

/* BENEFITS */
.bm { background: var(--warm-white); border: 1px solid var(--border); padding: 26px 30px; margin-bottom: 2px; }
.bg { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
.bi { display: flex; align-items: flex-start; gap: 10px; padding: 12px 14px; border: 1px solid var(--border-soft); background: var(--parchment); transition: all 0.2s; cursor: default; }
.bi:hover { border-color: var(--border); background: var(--cream); }
.bg-rust .bi:hover { background: var(--rust-light); border-color: rgba(196,81,42,0.25); }
.bg-gold .bi:hover { background: var(--gold-light); border-color: rgba(166,124,58,0.3); }
.bg-forest .bi:hover { background: var(--forest-light); border-color: rgba(45,92,62,0.3); }
.bg-navy .bi:hover { background: var(--navy-light); border-color: rgba(30,51,88,0.3); }
.bi-g { font-family: 'Playfair Display', serif; font-style: italic; font-size: 13px; flex-shrink: 0; margin-top: 1px; }
.gi-rust{color:var(--rust)} .gi-gold{color:var(--gold)} .gi-forest{color:var(--forest)} .gi-navy{color:var(--navy)}
.bi-t { font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 400; color: var(--ink-soft); line-height: 1.45; }

/* LIFECYCLE */
.lc { background: var(--warm-white); border: 1px solid var(--border); padding: 24px 30px; overflow-x: auto; margin-bottom: 2px; }
.lcs { display: flex; align-items: stretch; min-width: 740px; gap: 0; }
.lcs-stage { flex: 1; position: relative; text-align: center; }
.lcs-stage:not(:last-child)::after { content:''; position:absolute; right:-1px; top:50%; transform:translateY(-50%); width:0; height:0; border-top:7px solid transparent; border-bottom:7px solid transparent; border-left:9px solid var(--border); z-index:2; }
.si { margin: 0 2px; padding: 10px 6px; background: var(--parchment); border: 1px solid var(--border-soft); height: 100%; transition: all 0.2s; }
.si:hover { background: var(--navy-light); border-color: rgba(61,96,148,0.35); }
.si-num { font-family: 'Playfair Display', serif; font-style: italic; font-size: 17px; color: var(--navy); display: block; margin-bottom: 4px; }
.si-lbl { font-family: 'Space Grotesk', sans-serif; font-size: 10px; font-weight: 500; color: var(--ink-muted); line-height: 1.3; letter-spacing: 0.02em; }

/* SHIFT PANEL */
.sp { background: var(--warm-white); border: 1px solid var(--border); padding: 30px 32px; display: grid; grid-template-columns: 1fr 44px 1fr; gap: 20px; align-items: center; margin-bottom: 2px; }
.sb { padding: 20px 22px; border-radius: 1px; }
.sb-before { background: #FEF2F0; border: 1px solid #F0C0B4; }
.sb-after { background: var(--forest-light); border: 1px solid #A8CCBA; }
.sb-lbl { font-family: 'Space Grotesk', sans-serif; font-size: 9px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 8px; }
.sb-before .sb-lbl{color:#B84025} .sb-after .sb-lbl{color:var(--forest)}
.sb-q { font-family: 'Crimson Pro', serif; font-size: 16px; font-style: italic; line-height: 1.55; }
.sb-before .sb-q{color:#7A3020} .sb-after .sb-q{color:#1F4230} .sb-after .sb-q strong{font-style:normal;font-weight:600}
.sp-arr { text-align: center; font-family: 'Playfair Display', serif; font-style: italic; font-size: 22px; color: var(--ink-faint); }

/* DIVIDER */
.cdiv { height: 56px; display: flex; align-items: center; gap: 20px; margin: 8px 0; }
.cdiv-l { flex: 1; height: 1px; background: var(--border); }
.cdiv-m { font-family: 'Playfair Display', serif; font-style: italic; font-size: 14px; color: var(--ink-faint); letter-spacing: 0.1em; }

/* FINALE */
.finale { padding-top: 80px; opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.finale.visible { opacity: 1; transform: translateY(0); }
.finale-hd { text-align: center; margin-bottom: 48px; padding-bottom: 40px; border-bottom: 1px solid var(--border); }
.finale-hd .ol { font-family:'Space Grotesk',sans-serif; font-size:10px; font-weight:600; letter-spacing:0.2em; text-transform:uppercase; color:var(--rust); margin-bottom:16px; }
.finale-hd h2 { font-family:'Playfair Display',serif; font-size:clamp(28px,4vw,50px); font-weight:400; line-height:1.1; letter-spacing:-0.02em; color:var(--ink); }
.finale-hd h2 em { font-style:italic; color:var(--rust); }
.four-p { display:grid; grid-template-columns:repeat(4,1fr); gap:2px; background:var(--border); border:1px solid var(--border); margin-bottom:2px; }
.pillar { background:var(--warm-white); padding:30px 24px; position:relative; transition:background 0.2s; }
.pillar:hover { background:var(--parchment); }
.p-bg { font-family:'Playfair Display',serif; font-size:54px; font-weight:900; font-style:italic; line-height:1; opacity:0.07; position:absolute; top:14px; right:18px; color:var(--ink); }
.p-acc { width:30px; height:3px; margin-bottom:16px; border-radius:1px; }
.pa-rust{background:var(--rust)} .pa-gold{background:var(--gold)} .pa-forest{background:var(--forest)} .pa-navy{background:var(--navy)}
.pillar h3 { font-family:'Playfair Display',serif; font-size:17px; font-weight:700; line-height:1.2; margin-bottom:12px; color:var(--ink); }
.pillar p { font-family:'Crimson Pro',serif; font-size:15px; font-weight:300; color:var(--ink-muted); line-height:1.6; }

/* BANNER */
.formula-banner { background:var(--ink); padding:56px 48px; text-align:center; border:1px solid var(--border); }
.fb-sub { font-family:'Crimson Pro',serif; font-size:clamp(16px,2vw,20px); font-style:italic; color:rgba(255,255,255,0.45); margin-bottom:32px; line-height:1.55; }
.fr { display:flex; flex-wrap:wrap; justify-content:center; align-items:center; gap:12px; }
.ft { font-family:'Space Grotesk',sans-serif; font-size:clamp(10px,1.2vw,12px); font-weight:500; letter-spacing:0.1em; text-transform:uppercase; padding:10px 22px; }
.ft-rust{background:rgba(196,81,42,0.14);color:#F0946E;border:1px solid rgba(196,81,42,0.28)}
.ft-gold{background:rgba(166,124,58,0.14);color:#D4A854;border:1px solid rgba(166,124,58,0.28)}
.ft-forest{background:rgba(45,92,62,0.14);color:#70C291;border:1px solid rgba(45,92,62,0.28)}
.ft-navy{background:rgba(30,51,88,0.22);color:#80A0CC;border:1px solid rgba(61,96,148,0.38)}
.ft-res{background:rgba(255,255,255,0.07);color:#FFFDF9;border:1px solid rgba(255,255,255,0.18);font-size:clamp(11px,1.3vw,13px);font-weight:600}
.fs { font-family:'Playfair Display',serif; font-style:italic; font-size:22px; color:rgba(255,255,255,0.18); }

footer { position:relative; z-index:1; background:var(--warm-white); border-top:1px solid var(--border); padding:28px 48px; }
.fi { display:flex; align-items:center; justify-content:space-between; max-width:1160px; margin:0 auto; }
.f-logo { font-family:'Playfair Display',serif; font-size:12px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-faint); }
.f-note { font-family:'Crimson Pro',serif; font-size:13px; font-style:italic; color:var(--ink-faint); }

@media(max-width:900px){
  .four-p{grid-template-columns:1fr 1fr}
  .cg{grid-template-columns:1fr}
  .sp{grid-template-columns:1fr;grid-template-rows:auto auto auto}
  .sp-arr{transform:rotate(90deg)}
  nav{padding:14px 20px}
  .nav-links{display:none}
  main{padding:0 20px 80px}
  .hero{padding:100px 24px 70px}
  .formula-banner{padding:36px 20px}
  footer{padding:24px}
  .fi{flex-direction:column;gap:8px;text-align:center}
  .chapter-top{grid-template-columns:56px 1fr;gap:16px}
  .chapter-num{font-size:48px}
}
@media(max-width:600px){
  .four-p{grid-template-columns:1fr}
  .hero h1{font-size:36px}
}

/* ── MEASURABLE METRICS ── */
.metrics-section {
  background: var(--warm-white);
  border: 1px solid var(--border);
  padding: 32px 30px;
  margin-bottom: 2px;
}
.metrics-section .cell-head { margin-bottom: 24px; }

/* KPI BAR ROWS */
.kpi-grid { display: flex; flex-direction: column; gap: 14px; }
.kpi-row { display: grid; grid-template-columns: 200px 1fr 72px; gap: 14px; align-items: center; }
.kpi-label { font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 500; color: var(--ink-soft); letter-spacing: 0.03em; }
.kpi-track { height: 6px; background: var(--parchment); border: 1px solid var(--border-soft); border-radius: 1px; overflow: hidden; }
.kpi-fill { height: 100%; border-radius: 1px; width: 0; transition: width 1.4s cubic-bezier(0.4,0,0.2,1); }
.kpi-val { font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 700; text-align: right; }

.fill-rust { background: var(--rust); }
.fill-gold { background: var(--gold); }
.fill-forest { background: var(--forest); }
.fill-navy { background: var(--navy); }
.val-rust { color: var(--rust); }
.val-gold { color: var(--gold); }
.val-forest { color: var(--forest); }
.val-navy { color: var(--navy); }

/* COUNTER CARDS */
.counter-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 2px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 2px;
}
.counter-card {
  background: var(--warm-white);
  padding: 24px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: background 0.2s;
}
.counter-card:hover { background: var(--parchment); }
.counter-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
}
.cc-rust::after { background: var(--rust); }
.cc-gold::after { background: var(--gold); }
.cc-forest::after { background: var(--forest); }
.cc-navy::after { background: var(--navy); }
.cc-num {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 6px;
}
.cc-rust .cc-num { color: var(--rust); }
.cc-gold .cc-num { color: var(--gold); }
.cc-forest .cc-num { color: var(--forest); }
.cc-navy .cc-num { color: var(--navy); }
.cc-label {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ink-muted); line-height: 1.4;
}
.cc-sub {
  font-family: 'Crimson Pro', serif;
  font-size: 12px; font-style: italic;
  color: var(--ink-faint); margin-top: 4px; line-height: 1.4;
}

/* MASTER METRICS DASHBOARD */
.master-metrics {
  background: var(--warm-white);
  border: 1px solid var(--border);
  margin-bottom: 2px;
  padding: 36px 32px;
}
.mm-header {
  display: flex; align-items: baseline; gap: 16px;
  margin-bottom: 28px; padding-bottom: 20px;
  border-bottom: 1px solid var(--border-soft);
}
.mm-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px; font-weight: 700; color: var(--ink);
}
.mm-sub {
  font-family: 'Crimson Pro', serif;
  font-size: 14px; font-style: italic; color: var(--ink-faint);
}
.mm-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
}
.mm-card {
  padding: 20px;
  border: 1px solid var(--border-soft);
  background: var(--parchment);
  position: relative;
  transition: all 0.2s;
}
.mm-card:hover { background: var(--cream); border-color: var(--border); }
.mm-card-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 10px;
}
.mm-card-label {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
