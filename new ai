<script>
const io = new IntersectionObserver(e => e.forEach(x => { if(x.isIntersecting) x.target.classList.add('visible'); }), {threshold:0.07});
document.querySelectorAll('.chapter,.finale').forEach(el => io.observe(el));
function jmp(id){ const el=document.querySelector(id); if(el) el.scrollIntoView({behavior:'smooth',block:'start'}); }

/* ── ANIMATE COUNTERS ── */
function animateCounter(el) {
  const target = parseFloat(el.dataset.target);
  const suffix = el.dataset.suffix || '';
  const isDecimal = target % 1 !== 0;
  const duration = 1600;
  const start = performance.now();
  function tick(now) {
    const elapsed = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - elapsed, 3);
    const val = target * ease;
    el.textContent = (isDecimal ? val.toFixed(1) : Math.round(val)) + suffix;
    if (elapsed < 1) requestAnimationFrame(tick);
    else el.textContent = (Number.isInteger(target) ? target : target.toFixed(1)) + suffix;
  }
  requestAnimationFrame(tick);
}

/* ── ANIMATE KPI BARS ── */
function animateBars(container) {
  container.querySelectorAll('.kpi-fill, .mm-fill').forEach(fill => {
    const w = fill.dataset.width;
    if (w) fill.style.width = w + '%';
  });
}

/* ── INTERSECTION OBSERVER FOR METRICS ── */
const metricObs = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    const root = entry.target;
    root.querySelectorAll('[data-target]').forEach(el => {
      if (!el.dataset.animated) {
        el.dataset.animated = '1';
        animateCounter(el);
      }
    });
    animateBars(root);
    metricObs.unobserve(root);
  });
}, { threshold: 0.15 });

document.querySelectorAll('.counter-row, .metrics-section, .master-metrics, .stat-strip').forEach(el => {
  metricObs.observe(el);
});

/* Trigger stat-strip numbers too */
const statObs = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    entry.target.querySelectorAll('.stat-num').forEach(el => {
      if (!el.dataset.animated) {
        el.dataset.animated = '1';
      }
    });
  });
}, { threshold: 0.2 });
document.querySelectorAll('.stat-strip').forEach(el => statObs.observe(el));
</script>
